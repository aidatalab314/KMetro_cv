# macOS
.DS_Store

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
.env
.venv
kmetro/
env/
venv/

# Jupyter
.ipynb_checkpoints/

# Model weights — .engine 是 TensorRT 產物（綁定硬體，不進版控）
models/luggage/*.engine
models/fall_detection/*.engine

# Test videos (large files) — .gitkeep 保留目錄結構
data/test_videos/*
!data/test_videos/.gitkeep

# Output videos — .gitkeep 保留目錄結構
outputs/videos/*
!outputs/videos/.gitkeep

# Reference material
ref/

# Local config overrides (platform-specific, not versioned)
configs/cameras.local.yaml

# ROI records — drawn per machine/camera-mode; each machine keeps its own copy
configs/roi_records.json

# Event output (auto-generated) — .gitkeep 保留目錄結構
data/snapshots/*
!data/snapshots/.gitkeep
data/logs/*
!data/logs/.gitkeep

# Logs
*.log
