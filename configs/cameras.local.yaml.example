# cameras.local.yaml.example — 本機平台覆蓋設定範本
#
# 使用方式：
#   cp configs/cameras.local.yaml.example configs/cameras.local.yaml
#   # 依目前機器取消對應平台的註解
#
# 此檔案已加入 .gitignore，不進版控。
# git pull 不會覆蓋此檔案，兩台機器可各自維護獨立設定。
# configs/cameras.yaml 的值為預設值；此檔案只需填寫「與預設不同」的部分。

# ══════════════════════════════════════════════════════════════════════════════
# Mac Mini M1/M2（主要開發機）
# cameras.yaml 預設即為 Mac 設定（device: mps）
# 在家庭網路無法連到攝影機（192.168.6.x），改用本地測試影片
# 啟動指令：python src/pipeline/multistream.py --source local
# ══════════════════════════════════════════════════════════════════════════════
# detector:
#   device:       "mps"
#   skip_frames:  2
#
# features:
#   fall_detector:
#     imgsz: 640    # 覆蓋預設 1280（Mac MPS 效能考量）
#
# output:
#   save_video_rtsp:  false
#   save_video_local: true
#   mosaic_fps:       15    # source_fps(30) ÷ skip_frames(2) = 15


# ══════════════════════════════════════════════════════════════════════════════
# Ubuntu 24.04 + GeForce RTX 5060（推論機，實驗室 192.168.0.87）
# 啟動指令：python src/pipeline/multistream.py --source rtsp --mode op
# 前置：需先安裝 torchreid（pip install torchreid gdown tensorboard）
# ══════════════════════════════════════════════════════════════════════════════
# detector:
#   device:       "0"      # CUDA GPU 0
#   skip_frames:  1        # TensorRT 夠快；不足可改 2
#
# models:
#   person:     "models/fall_detection/yolo12l.engine"      # TensorRT FP16
#   luggage:    "models/luggage/yolo_luggage_best.engine"   # TensorRT FP16
#
# features:
#   dwell_monitor:
#     alert_seconds: 5.0   # 測試階段縮短；正式上線改回 60.0
#   fall_detector:
#     imgsz: 640
#     pose_fallback:
#       device: "0"        # RTMO 也用 CUDA（效能允許時才開 enabled: true）
#
# output:
#   save_video_rtsp:  false
#   save_video_local: false
#   mosaic_fps:       30    # source_fps(30) ÷ skip_frames(1) = 30
#
# reid:
#   enabled: true           # 啟用跨攝影機 Re-ID（需 torchreid 已安裝）
#   sim_threshold: 0.75     # cosine 相似度門檻（0.70=寬鬆, 0.80=嚴格）
#   ttl_sec: 300.0          # gallery TTL（秒）；超過視為人員已離站
#   model_path: ""          # 留空 → ImageNet；填路徑 → MSMT17 checkpoint


# ══════════════════════════════════════════════════════════════════════════════
# Ubuntu x86（無 GPU 的純 CPU 測試機）
# ══════════════════════════════════════════════════════════════════════════════
# detector:
#   device:      "cpu"
#   skip_frames: 4
#   imgsz:       640
#
# output:
#   save_video_local: false
#   save_mosaic:      false
#   mosaic_fps:       8
